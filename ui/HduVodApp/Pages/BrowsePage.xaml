<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HduVodApp.Pages.BrowsePage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:HduVodApp.Models"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Required"
    mc:Ignorable="d">

    <Grid Padding="20" RowSpacing="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 顶部：学期选择 -->
        <Grid Grid.Row="0" ColumnSpacing="12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="Auto" />
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>
            <TextBlock Text="学期" VerticalAlignment="Center"
                       Style="{StaticResource BodyStrongTextBlockStyle}" />
            <ComboBox x:Name="TermCombo" Grid.Column="1" MinWidth="220"
                      SelectionChanged="TermCombo_SelectionChanged" />
            <ProgressRing x:Name="TopBusy" Grid.Column="2" IsActive="False"
                          Width="22" Height="22" HorizontalAlignment="Left" />
            <Button Grid.Column="3" Content="刷新" Click="Refresh_Click" />
        </Grid>

        <!-- 主体：左课程 / 右录像 -->
        <Grid Grid.Row="1" ColumnSpacing="16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="360" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- 左：课程列表 -->
            <Border Grid.Column="0"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8">
                <Grid RowSpacing="8" Padding="12">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <TextBlock Grid.Row="0" Text="点播课程"
                               Style="{StaticResource SubtitleTextBlockStyle}" />
                    <ListView x:Name="CourseList" Grid.Row="1"
                              SelectionChanged="CourseList_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:CourseItem">
                                <StackPanel Padding="2,6">
                                    <TextBlock Text="{x:Bind Display}" TextWrapping="Wrap"
                                               Style="{StaticResource BodyStrongTextBlockStyle}" />
                                    <TextBlock Text="{x:Bind SubTitle}" TextWrapping="Wrap"
                                               FontSize="12"
                                               Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                </StackPanel>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Spacing="8"
                                HorizontalAlignment="Center">
                        <Button x:Name="PrevBtn" Content="上一页" Click="Prev_Click" />
                        <TextBlock x:Name="PageText" VerticalAlignment="Center" Text="-/-" />
                        <Button x:Name="NextBtn" Content="下一页" Click="Next_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <!-- 右：录像（按日期+时间） -->
            <Border Grid.Column="1"
                    Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8">
                <Grid Padding="12" RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- 头部：标题 + 全选 + 右上角批量下载 -->
                    <Grid Grid.Row="0" ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="SessionHeader"
                                   Text="请选择左侧课程"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource SubtitleTextBlockStyle}" />
                        <CheckBox x:Name="SelectAllBox" Grid.Column="1" Content="全选"
                                  Checked="SelectAll_Changed" Unchecked="SelectAll_Changed" />
                        <Button x:Name="BatchCopyBtn" Grid.Column="2" Content="复制选中链接"
                                IsEnabled="False" Click="BatchCopy_Click" />
                        <Button x:Name="BatchDownloadBtn" Grid.Column="3" Content="批量下载"
                                Style="{StaticResource AccentButtonStyle}"
                                IsEnabled="False" Click="BatchDownload_Click" />
                    </Grid>

                    <ListView x:Name="SessionList" Grid.Row="1"
                              SelectionMode="Multiple"
                              SelectionChanged="SessionList_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate x:DataType="models:SessionItem">
                                <Grid Padding="4,8" ColumnSpacing="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0" Width="150">
                                        <TextBlock Text="{x:Bind DateText}"
                                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                                        <TextBlock Text="{x:Bind TimeText}"
                                                   FontSize="12"
                                                   Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
                                    </StackPanel>
                                    <FontIcon Grid.Column="1" Glyph="&#xE786;" FontSize="14"
                                              Foreground="{ThemeResource TextFillColorTertiaryBrush}" />
                                    <TextBlock Grid.Column="2" Text="{x:Bind Title}"
                                               VerticalAlignment="Center" TextWrapping="Wrap" />
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>

                    <!-- 统一机位选择（应用于所有勾选的课） -->
                    <Border Grid.Row="2"
                            Background="{ThemeResource CardBackgroundFillColorSecondaryBrush}"
                            CornerRadius="6" Padding="12">
                        <StackPanel Spacing="10">
                            <TextBlock Text="画面选择（应用于所有勾选的课）"
                                       Style="{StaticResource BodyStrongTextBlockStyle}" />
                            <StackPanel Orientation="Horizontal" Spacing="20">
                                <CheckBox x:Name="ViewAll"
                                          Checked="ViewAll_Changed" Unchecked="ViewAll_Changed"
                                          ToolTipService.ToolTip="下载全部机位画面">
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Viewbox Width="38" VerticalAlignment="Center">
                                            <Canvas Width="44" Height="36">
                                                <Rectangle Canvas.Left="6"  Canvas.Top="6"  Width="14" Height="11" RadiusX="2" RadiusY="2"
                                                           Fill="{ThemeResource AccentFillColorDefaultBrush}" Opacity="0.3" />
                                                <Rectangle Canvas.Left="24" Canvas.Top="6"  Width="14" Height="11" RadiusX="2" RadiusY="2"
                                                           Fill="{ThemeResource AccentFillColorDefaultBrush}" Opacity="0.3" />
                                                <Rectangle Canvas.Left="6"  Canvas.Top="19" Width="14" Height="11" RadiusX="2" RadiusY="2"
                                                           Fill="{ThemeResource AccentFillColorDefaultBrush}" Opacity="0.3" />
                                                <Rectangle Canvas.Left="24" Canvas.Top="19" Width="14" Height="11" RadiusX="2" RadiusY="2"
                                                           Fill="{ThemeResource AccentFillColorDefaultBrush}" Opacity="0.3" />
                                            </Canvas>
                                        </Viewbox>
                                        <TextBlock Text="全部画面" VerticalAlignment="Center" />
                                    </StackPanel>
                                </CheckBox>
                                <CheckBox x:Name="View1"
                                          Checked="ViewNum_Changed" Unchecked="ViewNum_Changed"
                                          ToolTipService.ToolTip="后侧机位：摄像头在教室后方，向前拍讲台">
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Viewbox Width="38" VerticalAlignment="Center">
                                            <Canvas Width="44" Height="36">
                                                <!-- 教室 -->
                                                <Rectangle Canvas.Left="2" Canvas.Top="2" Width="40" Height="32" RadiusX="4" RadiusY="4"
                                                           Stroke="{ThemeResource TextFillColorTertiaryBrush}" StrokeThickness="1.2" />
                                                <!-- 讲台（前方） -->
                                                <Rectangle Canvas.Left="13" Canvas.Top="5" Width="18" Height="4" RadiusX="1.5" RadiusY="1.5"
                                                           Fill="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <!-- 视锥（自后向前） -->
                                                <Polygon Points="22,29 9,13 35,13" Opacity="0.28"
                                                         Fill="{ThemeResource AccentFillColorDefaultBrush}" />
                                                <!-- 摄像头（后方） -->
                                                <Ellipse Canvas.Left="18" Canvas.Top="25" Width="8" Height="8"
                                                         Fill="{ThemeResource AccentFillColorDefaultBrush}" />
                                            </Canvas>
                                        </Viewbox>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="后侧" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                            <TextBlock Text="自后向前" FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </CheckBox>
                                <CheckBox x:Name="View3"
                                          Checked="ViewNum_Changed" Unchecked="ViewNum_Changed"
                                          ToolTipService.ToolTip="前侧机位：摄像头在教室前方，向后拍全场">
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Viewbox Width="38" VerticalAlignment="Center">
                                            <Canvas Width="44" Height="36">
                                                <!-- 教室 -->
                                                <Rectangle Canvas.Left="2" Canvas.Top="2" Width="40" Height="32" RadiusX="4" RadiusY="4"
                                                           Stroke="{ThemeResource TextFillColorTertiaryBrush}" StrokeThickness="1.2" />
                                                <!-- 讲台（前方） -->
                                                <Rectangle Canvas.Left="13" Canvas.Top="4" Width="18" Height="4" RadiusX="1.5" RadiusY="1.5"
                                                           Fill="{ThemeResource TextFillColorSecondaryBrush}" />
                                                <!-- 视锥（自前向后） -->
                                                <Polygon Points="22,13 9,31 35,31" Opacity="0.28"
                                                         Fill="{ThemeResource AccentFillColorDefaultBrush}" />
                                                <!-- 摄像头（前方，讲台旁） -->
                                                <Ellipse Canvas.Left="18" Canvas.Top="9" Width="8" Height="8"
                                                         Fill="{ThemeResource AccentFillColorDefaultBrush}" />
                                            </Canvas>
                                        </Viewbox>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="前侧" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                            <TextBlock Text="自前向后" FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </CheckBox>
                                <CheckBox x:Name="View5"
                                          Checked="ViewNum_Changed" Unchecked="ViewNum_Changed"
                                          ToolTipService.ToolTip="电脑投屏 · 课件画面">
                                    <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                        <Viewbox Width="38" VerticalAlignment="Center">
                                            <Canvas Width="44" Height="36">
                                                <!-- 屏幕 -->
                                                <Rectangle Canvas.Left="7" Canvas.Top="6" Width="30" Height="20" RadiusX="2.5" RadiusY="2.5"
                                                           Fill="{ThemeResource AccentFillColorDefaultBrush}" Opacity="0.22" />
                                                <Rectangle Canvas.Left="7" Canvas.Top="6" Width="30" Height="20" RadiusX="2.5" RadiusY="2.5"
                                                           Stroke="{ThemeResource AccentFillColorDefaultBrush}" StrokeThickness="1.6" />
                                                <!-- 支架 -->
                                                <Rectangle Canvas.Left="20" Canvas.Top="26" Width="4" Height="4"
                                                           Fill="{ThemeResource AccentFillColorDefaultBrush}" />
                                                <Rectangle Canvas.Left="14" Canvas.Top="29" Width="16" Height="2.6" RadiusX="1.3" RadiusY="1.3"
                                                           Fill="{ThemeResource AccentFillColorDefaultBrush}" />
                                            </Canvas>
                                        </Viewbox>
                                        <StackPanel VerticalAlignment="Center">
                                            <TextBlock Text="电脑" Style="{StaticResource BodyStrongTextBlockStyle}" />
                                            <TextBlock Text="投屏画面" FontSize="11"
                                                       Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                                        </StackPanel>
                                    </StackPanel>
                                </CheckBox>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <ProgressRing x:Name="BatchBusy" IsActive="False" Width="20" Height="20" />
                                <TextBlock x:Name="BatchHint" VerticalAlignment="Center"
                                           Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                           Text="勾选上方录像后点「批量下载」" />
                            </StackPanel>
                            <InfoBar x:Name="BrowseInfo" IsOpen="False" IsClosable="True" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Page>
