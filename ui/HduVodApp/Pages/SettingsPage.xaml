<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HduVodApp.Pages.SettingsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    NavigationCacheMode="Enabled"
    mc:Ignorable="d">

    <Page.Resources>
        <Style x:Key="SettingCardStyle" TargetType="Border">
            <Setter Property="Background" Value="{ThemeResource CardBackgroundFillColorDefaultBrush}" />
            <Setter Property="BorderBrush" Value="{ThemeResource CardStrokeColorDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius" Value="8" />
            <Setter Property="Padding" Value="20,16" />
            <Setter Property="MinHeight" Value="68" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
    </Page.Resources>

    <ScrollViewer Padding="28,24"
                  HorizontalScrollMode="Disabled"
                  HorizontalScrollBarVisibility="Disabled">
        <StackPanel Spacing="14" HorizontalAlignment="Stretch">
            <TextBlock Text="设置" Style="{StaticResource TitleTextBlockStyle}"
                       Margin="0,0,0,6" />

            <TextBlock Text="下载"
                       Style="{StaticResource BodyStrongTextBlockStyle}"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       Margin="2,4,0,0" />

            <!-- 同时最大下载数 -->
            <Border Style="{StaticResource SettingCardStyle}">
                <Grid VerticalAlignment="Center" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="同时最大下载数"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="同一时间最多并行下载的任务数（1–10）"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <NumberBox x:Name="ConcurrentBox" Grid.Column="1"
                               VerticalAlignment="Center"
                               Minimum="1" Maximum="10" Value="2"
                               SpinButtonPlacementMode="Inline" MinWidth="160" />
                </Grid>
            </Border>

            <!-- 单文件并发线程数 -->
            <Border Style="{StaticResource SettingCardStyle}">
                <Grid VerticalAlignment="Center" ColumnSpacing="16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel VerticalAlignment="Center" Spacing="2">
                        <TextBlock Text="单文件并发线程数"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="同一文件的多连接分片数，aria2 上限 8（1–8）"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <NumberBox x:Name="ConnectionsBox" Grid.Column="1"
                               VerticalAlignment="Center"
                               Minimum="1" Maximum="8" Value="8"
                               SpinButtonPlacementMode="Inline" MinWidth="160" />
                </Grid>
            </Border>

            <!-- 默认下载目录 -->
            <Border Style="{StaticResource SettingCardStyle}">
                <StackPanel Spacing="10">
                    <StackPanel Spacing="2">
                        <TextBlock Text="默认下载目录"
                                   Style="{StaticResource BodyStrongTextBlockStyle}" />
                        <TextBlock Text="下载文件的保存位置，留空使用程序目录下的 downloads"
                                   FontSize="12"
                                   Foreground="{ThemeResource TextFillColorSecondaryBrush}" />
                    </StackPanel>
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="DirBox" PlaceholderText="默认 downloads 目录"
                                 HorizontalAlignment="Stretch" />
                        <Button Grid.Column="1" Content="浏览..." Click="Browse_Click"
                                MinWidth="96" />
                    </Grid>
                </StackPanel>
            </Border>

            <StackPanel Orientation="Horizontal" Spacing="10" Margin="0,4,0,0">
                <Button Content="保存设置" Style="{StaticResource AccentButtonStyle}"
                        MinWidth="120" Click="Save_Click" />
                <Button Content="恢复默认" MinWidth="120" Click="Reset_Click" />
            </StackPanel>

            <InfoBar x:Name="SaveInfo" IsOpen="False" IsClosable="True" />

            <TextBlock x:Name="Aria2Status" FontSize="12"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       TextWrapping="Wrap" Margin="2,4,0,0" />
        </StackPanel>
    </ScrollViewer>
</Page>
