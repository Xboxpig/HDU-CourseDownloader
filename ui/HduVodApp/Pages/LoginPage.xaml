<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="HduVodApp.Pages.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid Padding="0,40,0,0">
        <StackPanel Width="420"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center"
                    Spacing="16">

            <FontIcon Glyph="&#xE7F4;" FontSize="48" HorizontalAlignment="Center"
                      Foreground="{ThemeResource AccentTextFillColorPrimaryBrush}" />
            <TextBlock Text="HDU 录播下载器"
                       Style="{StaticResource TitleLargeTextBlockStyle}"
                       HorizontalAlignment="Center" />
            <TextBlock Text="登录课程平台以浏览并下载点播录像"
                       Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                       HorizontalAlignment="Center" />

            <Border Background="{ThemeResource LayerFillColorDefaultBrush}"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="24" Margin="0,12,0,0">
                <StackPanel Spacing="14">
                    <TextBox x:Name="UserBox" Header="学号 / 账号"
                             PlaceholderText="请输入账号" />
                    <PasswordBox x:Name="PassBox" Header="密码"
                                 PlaceholderText="请输入密码" />

                    <!-- 主操作（有已保存凭证时）：蓝色，排第一，直接进入 -->
                    <Button x:Name="UseCacheBtn" Content="使用已保存的凭证进入"
                            Style="{StaticResource AccentButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Visibility="Collapsed"
                            Click="OnUseCacheClick" />

                    <!-- 主操作（无已保存凭证时）：蓝色，登录刷新 -->
                    <Button x:Name="LoginBtn" Content="登录 / 刷新凭证"
                            Style="{StaticResource AccentButtonStyle}"
                            HorizontalAlignment="Stretch"
                            Click="OnLoginClick" />

                    <!-- 次操作（有已保存凭证时）：灰色，排第二，重新登录 -->
                    <Button x:Name="ReloginBtn" Content="重新登录（刷新凭证）"
                            HorizontalAlignment="Stretch"
                            Visibility="Collapsed"
                            Click="OnLoginClick" />

                    <StackPanel x:Name="BusyPanel" Orientation="Horizontal"
                                Spacing="10" Visibility="Collapsed"
                                HorizontalAlignment="Center">
                        <ProgressRing IsActive="True" Width="20" Height="20" />
                        <TextBlock x:Name="BusyText" VerticalAlignment="Center"
                                   Text="处理中..." />
                    </StackPanel>

                    <InfoBar x:Name="StatusBar" IsOpen="False" IsClosable="False" />
                </StackPanel>
            </Border>

            <TextBlock x:Name="LogText"
                       FontFamily="Consolas"
                       FontSize="11"
                       TextWrapping="Wrap"
                       Foreground="{ThemeResource TextFillColorTertiaryBrush}"
                       MaxHeight="120" />
        </StackPanel>
    </Grid>
</Page>
